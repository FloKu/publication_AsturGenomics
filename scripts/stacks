#### run analyses
sstacks -p 50 -P /media/inter/mchai/AccipiterGenomics/results/Stacks/11032022_LibA -M /media/inter/mchai/AccipiterGenomics/data/population_map/popmap_LibA.txt

""" > /media/inter/mchai/AccipiterGenomics/shell/LibA_sstacks_qsub

qsub /media/inter/mchai/AccipiterGenomics/shell/LibA_sstacks_qsub

