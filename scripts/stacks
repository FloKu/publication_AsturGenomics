module load NGSmapper/stacks-2.59

#### run analyses
populations -P /media/inter/mchai/AccipiterGenomics/results/Stacks/11032022_LibA --vcf -t 50 -M /media/inter/mchai/AccipiterGenomics/data/population_map/popmap_LibA.txt -O /media/inter/mchai/AccipiterGenomics/results/Stacks/Output_stacks -r 0.65 --genepop --structure --fstats --hwe

""" > /media/inter/mchai/AccipiterGenomics/shell/LibA_populations_qsub

qsub /media/inter/mchai/AccipiterGenomics/shell/LibA_populations_qsub
