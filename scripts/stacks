tsv2bam -P /media/inter/mchai/AccipiterGenomics/results/Stacks/11032022_LibA -M /media/inter/mchai/AccipiterGenomics/data/population_map/popmap_LibA.txt -R /media/inter/mchai/AccipiterGenomics/results/Stacks/demultiplexed/LibA -t 50

""" > /media/inter/mchai/AccipiterGenomics/shell/LibA_tsv2bam_qsub

