############################
#ustacks
###########################
echo '''
#!/bin/sh # the shebang - needed so that the sh is called (the hash in the shebang is part of the command)
## Script to run uSTACKS, Florian Kunz
# version 11.03.22
# This sub-script of main.sh will run uSTACKS on the output of the process_radtags

# It implemets a loop over all individuals in the respective folder#
# For paired-end data, only the forward runs need to be analysed - the reverse runs will be inlcuded later in tsv2bam

# 0) openPBS
#********************
#PBS -N Min_uSTACKS
#PBS -o /media/inter/mchai/AccipiterGenomics/PBSoutput.logfiles
#PBS -j oe
#PBS -l select=1:ncpus=20:mem=200gb

# 1) preface
#*******************
module load NGSmapper/stacks-2.59
# module load NGSmapper/stacks-2.60 this one is not working

# 3) Run uSTACKS
#*******************
j=0

for i in /media/inter/mchai/AccipiterGenomics/results/Stacks/demultiplexed/LibA/*.1.fq.gz

do
  j=$((++j))

  ## extract ID of sample
  tmp=${i##*/}
  ID=${tmp%%.*}

  ustacks \
  -t gzfastq \
  -f /media/inter/mchai/AccipiterGenomics/results/Stacks/demultiplexed/LibA/${ID}.1.fq.gz \
  -o /media/inter/mchai/AccipiterGenomics/results/Stacks/11032022_LibA \
  -i ${j} \
  --force-diff-len \
  --name ${ID} \
  -p 2

done

# Potential alternative?: The uSTACKS command includes $ because it will loop over all indidivuals in the folder
# ustacks -t fq.gz -f ${i} -o /media/inter/fkunz/GrouseGenomics/results/STACKS_subset -i ${j} --name ${ID} --force-diff-len -p 2

''' > /media/inter/mchai/AccipiterGenomics/shell/uSTACKS_qsub.sh

qsub /media/inter/mchai/AccipiterGenomics/shell/uSTACKS_qsub.sh

#####################################################################################
#cstacks
#####################################################################################

## name of Job
#PBS -N Stacks_LibA

## redirect output stream to this file
#PBS -o /media/inter/mchai/AccipiterGenomics/PBSoutput.logfiles

## Stream Standard output and standard Error to outputfile
#PBS -j oe

## Select a maximum of 200 cores and 400gb of RAM
#PBS -l select=1:ncpus=50:mem=200gb

#### load dependencies
module load NGSmapper/stacks-2.59

#### run analyses
cstacks -n 6 -p 50 -P /media/inter/mchai/AccipiterGenomics/results/Stacks/11032022_LibA -M /media/inter/mchai/AccipiterGenomics/data/population_map/popmap_LibA.txt

""" > /media/inter/mchai/AccipiterGenomics/shell/LibA_cstacks_qsub

qsub /media/inter/mchai/AccipiterGenomics/shell/LibA_cstacks_qsub

#########################################
# 11.03.2022 running sstacks on LibA
#########################################
