#########################################
# 11.03.2022 running populations on LibA
#########################################
mkdir /media/inter/mchai/AccipiterGenomics/results/Stacks/Output_stacks

echo """
#!/bin/sh

## name of Job
#PBS -N populations_LibA

## redirect output stream to this file
#PBS -o /media/inter/mchai/AccipiterGenomics/PBSoutput.logfiles

## Stream Standard output and standard Error to outputfile
#PBS -j oe

## Select a maximum of 200 cores and 400gb of RAM
#PBS -l select=1:ncpus=50:mem=200gb

